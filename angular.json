{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "cli": {
    "analytics": false,
    "defaultCollection": "@angular-eslint/schematics"
  },
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "core-util": {
      "root": "core-util",
      "sourceRoot": "core-util",
      "projectType": "library",
      "prefix": "ku",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "core-util/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "core-util/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "core-util/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "main": "core-util/test.ts",
            "tsConfig": "core-util/tsconfig.spec.json",
            "karmaConfig": "core-util/karma.conf.js"
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "core-util/**/*.ts",
              "core-util/**/*.html"
            ]
          }
        }
      }
    },
    "core-misc": {
      "root": "core-misc",
      "sourceRoot": "core-misc",
      "projectType": "library",
      "prefix": "ku",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "core-misc/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "core-misc/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "core-misc/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "main": "core-misc/test.ts",
            "tsConfig": "core-misc/tsconfig.spec.json",
            "karmaConfig": "core-misc/karma.conf.js"
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "core-misc/**/*.ts",
              "core-misc/**/*.html"
            ]
          }
        }
      }
    },
    "core-translate": {
      "root": "core-translate",
      "sourceRoot": "core-translate",
      "projectType": "library",
      "prefix": "ku",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "core-translate/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "core-translate/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "core-translate/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "main": "core-translate/test.ts",
            "tsConfig": "core-translate/tsconfig.spec.json",
            "karmaConfig": "core-translate/karma.conf.js"
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "core-translate/**/*.ts",
              "core-translate/**/*.html"
            ]
          }
        }
      }
    }
  },
  "defaultProject": "core-util"
}
